{
  "expo": {
    "name": "Gambit Flash Cards",
    "slug": "gambit-flash-cards",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "gambit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2EDC2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gambit.flashcards",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Usamos reconhecimento de voz para você controlar os flashcards sem tocar na tela.",
        "NSMicrophoneUsageDescription": "Usamos o microfone para reconhecer seus comandos de voz durante o estudo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2EDC2"
      },
      "package": "com.gambit.flashcards",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Usamos o microfone para reconhecer seus comandos de voz durante o estudo.",
          "speechRecognitionPermission": "Usamos reconhecimento de voz para você controlar os flashcards sem tocar na tela."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2c51d9f-9c08-4974-994b-1d7e641829c0"
      }
    }
  }
}
